{
  "modelProviders": {
    "openai": [
      {
        "id": "qwen3-coder-next",
        "name": "Qwen3 Coder Next",
        "envKey": "QWEN_API_KEY",
        "baseUrl": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "generationConfig": {
          "timeout": 300000,
          "maxRetries": 1,
          "contextWindowSize": 262144,
          "samplingParams": {
            "temperature": 0.7,
            "max_tokens": 32768
          }
        }
      }
    ]
  },
  "model": {
    "name": "qwen3-coder-next"
  },
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "webSearch": {
    "provider": [
      {
        "type": "tavily",
        "apiKey": "not-needed"
      }
    ],
    "default": "tavily"
  },
  "$version": 3,
  "permissions": {
    "allow": [
      "WebFetch(playwright.dev)",
      "WebFetch(www.npmsearch.com)",
      "WebFetch(github.com)",
      "WebSearch"
    ]
  }
}
