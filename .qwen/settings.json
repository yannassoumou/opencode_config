{
  "modelProviders": {
    "openai": [
      {
        "id": "qwen35-moe-35b",
        "name": "Qwen3.5 MOE 35B (Reasoning)",
        "envKey": "OPENAI_API_KEY",
        "baseUrl": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "generationConfig": {
          "timeout": 300000,
          "maxRetries": 3,
          "contextWindowSize": 262144,
          "samplingParams": {
            "temperature": 0.6,
            "top_p": 0.95,
            "max_tokens": 32768
          }
        }
      },
      {
        "id": "qwen3-coder-next",
        "name": "Qwen3 Coder Next (Specialized)",
        "envKey": "OPENAI_API_KEY",
        "baseUrl": "http://minisforum.tailfe1a8c.ts.net:8081/v1",
        "generationConfig": {
          "timeout": 300000,
          "maxRetries": 3,
          "contextWindowSize": 262144,
          "samplingParams": {
            "temperature": 0.6,
            "top_p": 0.95,
            "max_tokens": 32768
          }
        }
      },
      {
        "id": "qwen35-9b-q4-k-m",
        "name": "Qwen3.5 9B Q4 (Lightweight/Fast)",
        "envKey": "OPENAI_API_KEY",
        "baseUrl": "http://station.tailfe1a8c.ts.net:8080/v1",
        "generationConfig": {
          "timeout": 180000,
          "maxRetries": 2,
          "contextWindowSize": 65536,
          "samplingParams": {
            "temperature": 0.5,
            "top_p": 0.95,
            "max_tokens": 16384
          }
        }
      }
    ]
  },
  "model": {
    "name": "qwen3-coder-next",
    "description": "Primary coding model - routes tasks intelligently based on complexity"
  },
  "modelRouting": {
    "enabled": true,
    "rules": [
      {
        "pattern": "architecture|design|planning|refactor.*complex|system.*design|multi.*file",
        "model": "qwen35-moe-35b",
        "description": "Route complex architectural tasks to MOE model"
      },
      {
        "pattern": "debug|error|exception|trace|stack",
        "model": "qwen3-coder-next",
        "description": "Route debugging tasks to specialized coder"
      },
      {
        "pattern": "optimize|performance|profil|bottleneck",
        "model": "qwen3-coder-next",
        "description": "Route optimization tasks to specialized coder"
      },
      {
        "pattern": "review|audit|quality|best.*practice",
        "model": "qwen3-coder-next",
        "description": "Route code review tasks to specialized coder"
      },
      {
        "pattern": "documentation|writing|comment|docstring|readme",
        "model": "qwen35-moe-35b",
        "description": "Route writing tasks to MOE for better prose"
      },
      {
        "pattern": "quick.*fix|minor.*edit|simple.*change|typo|format|lint",
        "model": "qwen35-9b-q4-k-m",
        "description": "Route lightweight tasks to 9B for speed"
      },
      {
        "pattern": "git|commit|branch|merge|rebase|tag",
        "model": "qwen35-9b-q4-k-m",
        "description": "Route git operations to lightweight 9B model"
      },
      {
        "pattern": "explore|search|find|grep|list",
        "model": "qwen35-9b-q4-k-m",
        "description": "Route exploration tasks to fast 9B model"
      },
      {
        "pattern": "test|unit.*test|integration.*test|spec",
        "model": "qwen3-coder-next",
        "description": "Route testing tasks to specialized coder"
      }
    ]
  },
  "security": {
    "auth": {
      "selectedType": "qwen-oauth"
    }
  },
  "$version": 4
}
