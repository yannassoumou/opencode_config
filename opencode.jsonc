{
  "$schema": "https://opencode.ai/config.json",
  "model": "local-llm8080/qwen3-coder-next",
  "provider": {
    "local-llm8080": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Strix Halo (llama.cpp)",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen3-coder-next": {
          "name": "qwen3-coder-next",
          "cost": {
            "input": 0.3,
            "output": 0.3,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },
    "wsl-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "wsl-llm (llama.cpp)",
      "options": {
        "baseURL": "http://wsl-windows.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen3.5-9b-q4-k-m": {
          "name": "qwen3.5-9b-q4-k-m",
          "cost": {
            "input": 0,
            "output": 0,
          },
          "limit": {
            "context": 65536,
            "output": 16384,
          },
        },
      },
    },

    // WSL host llama.cpp (same stack as browser UI at wsl-windows:8080 — API is /v1, not #/chat/...)
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384,
  },
  "plugin": ["oh-my-opencode@latest"],
}
