{
  "$schema": "https://opencode.ai/config.json",
  "model": "local-llm/qwen35-122b-mxp",
  "provider": {
    "local-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Strix Halo (llama.cpp)",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen35-122b-mxp": {
          "name": "qwen35-122b-mxp",
          "cost": {
            "input": 0.3,
            "output": 0.3,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
        "qwen35-moe-35b": {
          "name": "qwen35-moe-35b",
          "cost": {
            "input": 0.3,
            "output": 0.3,
          },
          "limit": {
            "context": 131072,
            "output": 32768,
          },
        },
      },
    },
    // WSL host llama.cpp (same stack as browser UI at wsl-windows:8080 — API is /v1, not #/chat/...)
    "wsl-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "WSL Windows (llama.cpp)",
      "options": {
        "baseURL": "http://wsl-windows.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "nemotron-nano-4b": {
          "name": "nemotron-nano-4b",
          "cost": {
            "input": 0,
            "output": 0,
          },
          "limit": {
            "context": 103424,
            "output": 16384,
          },
        },
      },
    },
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384,
  },
  "plugin": ["oh-my-opencode@latest"],
}
