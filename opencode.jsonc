{
  "$schema": "https://opencode.ai/config.json",

  // Primary model: Qwen3.5-MOE on port 8080 for most tasks
  "model": "local-llm8080/qwen35-moe-35b",

  // ============================================================================
  // PROVIDERS - Dual local endpoints
  // ============================================================================
  "provider": {
    // Port 8080: Qwen3.5-35B-A3B (MOE) - Primary general-purpose model
    "local-llm8080": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Minisforum Port 8080 - Qwen3.5-MOE-35B",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen35-moe-35b": {
          "name": "qwen35-moe-35b",
          "cost": {
            "input": 0,
            "output": 0,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },

    // Port 8081: Qwen3-Coder-Next (Q6_K_XL) - Specialized for coding
    "local-llm8081": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Minisforum Port 8081 - Qwen3-Coder-Next (Q6_K_XL)",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen3-coder-next": {
          "name": "qwen3-coder-next",
          "cost": {
            "input": 0,
            "output": 0,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },

    // WSL host llama.cpp (fallback option)
    "wsl-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "WSL-Windows llama.cpp (fallback)",
      "options": {
        "baseURL": "http://station.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen3.5-9b-q4-k-m": {
          "name": "qwen3.5-9b-q4-k-m",
          "cost": {
            "input": 0,
            "output": 0,
          },
          "limit": {
            "context": 65536,
            "output": 16384,
          },
        },
      },
    },
  },
  // ============================================================================
  // ADVANCED SETTINGS
  // ============================================================================
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384,
  },

  "plugin": ["oh-my-opencode@latest"],
}
