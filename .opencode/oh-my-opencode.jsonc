{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",

  // Primary model: qwen35-moe on local-llm8081 for fast execution
  "model": "local-llm8081/qwen35-moe-35b",

  // ============================================================================
  // AGENTS - Core orchestrators with updated model strategy
  // ============================================================================
  "agents": {
    // Main orchestrator: qwen35-moe for fast coordination
    "sisyphus": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
    },

    // Architecture consultation: qwen3-coder for deep reasoning
    "oracle": {
      "model": "local-llm8080/qwen3-coder-next",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["local-llm8081/qwen35-moe-35b"],
      "prompt_append": "Focus on architectural patterns, system design, and long-horizon reasoning. Consider scalability and maintainability.",
    },

    // Research agent: qwen35-moe for lightweight triage/exploration
    "librarian": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
    },

    // Exploration/investigation: qwen35-moe for speed
    "explore": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
    },

    // Metaprogramming tasks: qwen3-coder for deep code analysis
    "metis": {
      "model": "local-llm8080/qwen3-coder-next",
      "temperature": 1.0,
      "stream": false,
      "fallback_models": ["local-llm8081/qwen35-moe-35b"],
      "prompt_append": "Provide careful analysis of code patterns, potential optimizations, and edge cases.",
    },

    // Code fixing: qwen3-coder for specialized debugging
    "hephaestus": {
      "model": "local-llm8080/qwen3-coder-next",
      "temperature": 0.6,
      "stream": false,
      "maxTokens": 16384,
      "fallback_models": ["local-llm8081/qwen35-moe-35b"],
    },

    // Prometheus: qwen35-moe orchestrator with coder fallback
    "prometheus": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 0.6,
      "prompt_append": "Prioritize leveraging deep agents (oracle, metis) in parallel for complex analysis.",
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
    },

    // Sisyphus-Junior: qwen35-moe for fast task execution coordination
    "sisyphus-junior": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Subagent executor for category-based task delegation",
    },

    // OpenCode-Builder: qwen35-moe for fast task system execution
    "OpenCode-Builder": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Builds and executes complex tasks via the task system",
    },

    // Plan agent: qwen35-moe for fast planning
    "plan": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Generates structured work plans for multi-step tasks",
    },

    // Build agent: qwen35-moe for fast build/test operations
    "build": {
      "model": "local-llm8081/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 16384,
      "stream": false,
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Handles build, test, and lint operations",
    },
  },

  // ============================================================================
  // CATEGORIES - Task classification with optimized model assignment
  // ============================================================================
  "categories": {
    // Trivial tasks - qwen35-moe for speed
    "quick": {
      "model": "local-llm8081/qwen35-moe-35b",
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Quick fixes, minor edits, simple refactoring",
    },

    // Standard code generation - qwen35-moe for speed
    "unspecified-low": {
      "model": "local-llm8081/qwen35-moe-35b",
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Standard code generation and modifications",
    },

    // Complex tasks - qwen35-moe for fast response, fallback to coder if needed
    "unspecified-high": {
      "model": "local-llm8081/qwen35-moe-35b",
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Complex refactoring, architecture decisions, multi-file changes",
    },

    // Documentation - qwen35-moe for fast writing
    "writing": {
      "model": "local-llm8081/qwen35-moe-35b",
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Documentation, comments, and prose writing",
    },

    // Git operations - qwen35-moe for lightweight operations
    "git": {
      "model": "local-llm8081/qwen35-moe-35b",
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Git operations, commit messages, branch management",
    },

    // Debugging - qwen3-coder for specialized debugging expertise
    "debugging": {
      "model": "local-llm8080/qwen3-coder-next",
      "fallback_models": ["local-llm8081/qwen35-moe-35b"],
      "description": "Bug investigation, error analysis, root cause analysis",
    },

    // Performance optimization - qwen3-coder for expert analysis
    "optimization": {
      "model": "local-llm8080/qwen3-coder-next",
      "fallback_models": ["local-llm8081/qwen35-moe-35b"],
      "description": "Performance analysis, bottleneck identification, optimization strategies",
    },

    // Code review - qwen3-coder for thorough quality analysis
    "code-review": {
      "model": "local-llm8080/qwen3-coder-next",
      "fallback_models": ["local-llm8081/qwen35-moe-35b"],
      "description": "Code review, quality analysis, best practices",
    },

    // Visual/UI work - qwen35-moe for frontend speed
    "visual-engineering": {
      "model": "local-llm8081/qwen35-moe-35b",
      "fallback_models": ["local-llm8080/qwen3-coder-next"],
      "description": "Frontend, UI/UX, design, styling, animation",
    },
  },

  // ============================================================================
  // FEATURES - Enable task system for category delegation
  // ============================================================================
  "new_task_system_enabled": true,

  // ============================================================================
  // PROVIDERS - Updated local LLM configuration
  // ============================================================================
  "provider": {
    // Primary provider: qwen35-moe on port 8081 (fast execution)
    "local-llm8081": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Strix Halo (llama.cpp) - Port 8081",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8081/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen35-moe-35b": {
          "name": "qwen35-moe-35b",
          "cost": {
            "input": 0.2,
            "output": 0.2,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },

    // Secondary provider: qwen3-coder on port 8080 (specialized debugging/fixes)
    "local-llm8080": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Strix Halo (llama.cpp) - Port 8080",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen3-coder-next": {
          "name": "qwen3-coder-next",
          "cost": {
            "input": 0.3,
            "output": 0.3,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },

    // WSL provider: DISABLED BY DEFAULT (unreliable)
    // Uncomment and use only if WSL endpoint becomes stable
    // "wsl-llm": {
    //   "npm": "@ai-sdk/openai-compatible",
    //   "name": "wsl-llm (llama.cpp) - NOT RECOMMENDED",
    //   "options": {
    //     "baseURL": "http://wsl-windows.tailfe1a8c.ts.net:8080/v1",
    //     "apiKey": "not-needed",
    //   },
    //   "models": {
    //     "qwen3.5-9b-q4-k-m": {
    //       "name": "qwen3.5-9b-q4-k-m",
    //       "cost": {
    //         "input": 0,
    //         "output": 0,
    //       },
    //       "limit": {
    //         "context": 65536,
    //         "output": 16384,
    //       },
    //     },
    //   },
    // },
  },

  // ============================================================================
  // BACKGROUND TASKS - Concurrency and request management
  // ============================================================================
  "background_task": {
    "providerConcurrency": {
      // Both providers can handle parallel requests
      "local-llm8081": 8,
      "local-llm8080": 6,
    },
    "modelConcurrency": {
      // qwen35-moe: fast execution, can handle more concurrent requests
      "local-llm8081/qwen35-moe-35b": 4,
      // qwen3-coder: specialized tasks, moderate concurrency
      "local-llm8080/qwen3-coder-next": 3,
    },
  },

  // ============================================================================
  // FEATURES - Tools, hooks, and integrations
  // ============================================================================
  "skills": {
    "enabled": true,
  },

  "hooks": {
    "enabled": true,
    "disabled_hooks": [],
  },

  "commands": {
    "enabled": true,
  },

  "browser_automation": {
    "enabled": false,
  },

  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
  },

  "comment_checker": {
    "enabled": true,
  },

  "notification": {
    "force_enable": true,
  },

  "disabled_mcps": ["websearch", "grep_app"],

  // ============================================================================
  // ADVANCED FEATURES - Robust fallback and error handling
  // ============================================================================
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 30,
    "timeout_seconds": 60,
    "notify_on_fallback": true,
  },

  "hashline_edit": true,

  // ============================================================================
  // EXPERIMENTAL FEATURES - Optimizations for local models
  // ============================================================================
  "experimental": {
    "truncate_all_tool_outputs": false,
    "aggressive_truncation": true,
    "auto_resume": true,
    "disable_omo_env": false,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 2,
      },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search",
      ],
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 3 },
      },
    },
  },

  // ============================================================================
  // TMUX INTEGRATION
  // ============================================================================
  "tmux": {
    "enabled": false,
  },
}
