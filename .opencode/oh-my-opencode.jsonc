{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",

  // Primary model: Qwen3.5-MOE on local-llm8080 for orchestration and reasoning
  "model": "local-llm8080/qwen35-moe-35b",

  // ============================================================================
  // AGENTS - Strategically distributed across dual endpoints
  // ============================================================================
  "agents": {
    // Main orchestrator - needs strong reasoning, use MOE
    "sisyphus": {
      "model": "local-llm8080/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
    },

    // Architecture consultation - needs reasoning, use MOE
    "oracle": {
      "model": "local-llm8080/qwen35-moe-35b",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "prompt_append": "Focus on architectural patterns, system design, and long-horizon reasoning. Consider scalability and maintainability.",
    },

    // Research agent - benefits from MOE's broader knowledge
    "librarian": {
      "model": "local-llm8080/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
    },

    // Exploration/investigation - lightweight tasks use 9B
    "explore": {
      "model": "wsl-llm/qwen35-9b-q4-k-m",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
      "description": "Quick code exploration and simple investigation",
    },

    // Metaprogramming/code analysis - specialized coder model
    "metis": {
      "model": "local-llm8081/qwen3-coder-next",
      "temperature": 1.0,
      "stream": false,
      "prompt_append": "Provide careful analysis of code patterns, potential optimizations, and edge cases.",
    },

    // Code fixing - lightweight tasks use 9B
    "hephaestus": {
      "model": "wsl-llm/qwen35-9b-q4-k-m",
      "temperature": 0.6,
      "stream": false,
      "maxTokens": 8192,
      "description": "Quick code fixes and simple repairs",
    },

    // Prometheus - meta-coordinator, use MOE for orchestration
    "prometheus": {
      "model": "local-llm8080/qwen35-moe-35b",
      "temperature": 0.6,
      "prompt_append": "Prioritize leveraging deep agents (oracle, metis) in parallel for complex analysis.",
      "stream": false,
    },

    // Sisyphus-Junior - task delegator, use MOE for routing decisions
    "sisyphus-junior": {
      "model": "local-llm8080/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Subagent executor for category-based task delegation",
    },

    // OpenCode-Builder - code building, use coder model
    "OpenCode-Builder": {
      "model": "local-llm8081/qwen3-coder-next",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Builds and executes complex tasks via the task system",
    },

    // Plan agent - needs reasoning for planning, use MOE
    "plan": {
      "model": "local-llm8080/qwen35-moe-35b",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Generates structured work plans for multi-step tasks",
    },

    // Build agent - execution focused, lightweight tasks use 9B
    "build": {
      "model": "wsl-llm/qwen35-9b-q4-k-m",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 8192,
      "stream": false,
      "description": "Handles simple build, test, and lint operations",
    },
  },

  // ============================================================================
  // CATEGORIES - Distributed across endpoints based on task type
  // ============================================================================
  "categories": {
    "quick": {
      "model": "wsl-llm/qwen35-9b-q4-k-m",
      "description": "Quick fixes, minor edits, simple refactoring - lightweight tasks",
    },

    "unspecified-low": {
      "model": "wsl-llm/qwen35-9b-q4-k-m",
      "description": "Simple code generation, minor modifications - lightweight tasks",
    },

    "unspecified-high": {
      "model": "local-llm8080/qwen35-moe-35b",
      "description": "Complex refactoring, architecture decisions, multi-file changes",
    },

    "writing": {
      "model": "local-llm8080/qwen35-moe-35b",
      "description": "Documentation, comments, and prose writing",
    },

    "git": {
      "model": "wsl-llm/qwen35-9b-q4-k-m",
      "description": "Git operations, commit messages, branch management - simple patterns",
    },

    "debugging": {
      "model": "local-llm8081/qwen3-coder-next",
      "description": "Bug investigation, error analysis, root cause analysis",
    },

    "optimization": {
      "model": "local-llm8081/qwen3-coder-next",
      "description": "Performance analysis, bottleneck identification, optimization strategies",
    },

    "code-review": {
      "model": "local-llm8081/qwen3-coder-next",
      "description": "Code review, quality analysis, best practices",
    },

    "visual-engineering": {
      "model": "local-llm8080/qwen35-moe-35b",
      "description": "Frontend, UI/UX, design, styling, animation",
    },
  },

  // ============================================================================
  // FEATURES - Enable task system for category delegation
  // ============================================================================
  "new_task_system_enabled": true,

  // ============================================================================
  // PROVIDERS - Dual local endpoints + WSL fallback
  // ============================================================================
  "provider": {
    // Port 8080: Qwen3.5-35B-A3B (MOE) - Primary for reasoning/architecture
    "local-llm8080": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Minisforum Port 8080 - Qwen3.5-MOE-35B",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen35-moe-35b": {
          "name": "qwen35-moe-35b",
          "cost": {
            "input": 0.3,
            "output": 0.3,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },

    // Port 8081: Qwen3-Coder-Next (Q6_K_XL) - Specialized for coding
    "local-llm8081": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Minisforum Port 8081 - Qwen3-Coder-Next (Q6_K_XL)",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8081/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen3-coder-next": {
          "name": "qwen3-coder-next",
          "cost": {
            "input": 0.6,
            "output": 0.6,
          },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },

    // WSL host llama.cpp - Qwen3.5-9B (65k context) fallback
    "wsl-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "WSL-Windows llama.cpp - Qwen3.5-9B (fallback)",
      "options": {
        "baseURL": "http://station.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen35-9b-q4-k-m": {
          "name": "qwen35-9b-q4-k-m",
          "cost": {
            "input": 0,
            "output": 0,
          },
          "limit": {
            "context": 65536,
            "output": 16384,
          },
        },
      },
    },
  },

  // ============================================================================
  // BACKGROUND TASKS - Concurrency and request management
  // ============================================================================
  "background_task": {
    "providerConcurrency": {
      "local-llm8080": 6,
      "local-llm8081": 6,
      "wsl-llm": 4,
    },
    "modelConcurrency": {
      "local-llm8080/qwen35-moe-35b": 4,
      "local-llm8081/qwen3-coder-next": 4,
      "wsl-llm/qwen35-9b-q4-k-m": 2,
    },
  },

  // ============================================================================
  // FEATURES - Tools, hooks, and integrations
  // ============================================================================
  "skills": {
    "enabled": true,
  },

  "hooks": {
    "enabled": true,
    "disabled_hooks": [],
  },

  "commands": {
    "enabled": true,
  },

  "browser_automation": {
    "enabled": false,
  },

  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
  },

  "comment_checker": {
    "enabled": true,
  },

  "notification": {
    "force_enable": true,
  },

  "disabled_mcps": ["websearch", "grep_app"],

  // ============================================================================
  // ADVANCED FEATURES - Robust fallback and error handling
  // ============================================================================
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 30,
    "timeout_seconds": 60,
    "notify_on_fallback": true,
  },

  "hashline_edit": true,

  // ============================================================================
  // EXPERIMENTAL FEATURES - Optimizations for local models
  // ============================================================================
  "experimental": {
    "truncate_all_tool_outputs": false,
    "aggressive_truncation": true,
    "auto_resume": true,
    "disable_omo_env": false,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 2,
      },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search",
      ],
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 3 },
      },
    },
  },

  // ============================================================================
  // TMUX INTEGRATION
  // ============================================================================
  "tmux": {
    "enabled": false,
  },
}
