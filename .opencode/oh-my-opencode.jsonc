{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Default model for top-level delegation
  "model": "local-llm/qwen35-122b-mxp",

  // ============================================================================
  // AGENTS
  // ============================================================================
  "agents": {
    // Main orchestrator — 122b-mxp for quality output + full 131K context
    "sisyphus": {
      "model": "local-llm/qwen35-122b-mxp",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["local-llm/qwen35-moe-35b"],
    },

    // Architecture consultation — 122b-mxp deep reasoning
    "oracle": {
      "model": "local-llm/qwen35-122b-mxp",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["wsl-llm/nemotron-nano-4b"],
      "prompt_append": "Focus on architectural patterns, system design, and long-horizon reasoning. Consider scalability and maintainability.",
    },

    // Research/triage — 35b fast enough, saves 122b slots
    "librarian": {
      "model": "local-llm/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
    },

    // Exploration — 35b lightweight
    "explore": {
      "model": "local-llm/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
    },

    // Metaprogramming — 122b-mxp deep reasoning + large context for big codebases
    "metis": {
      "model": "local-llm/qwen35-122b-mxp",
      "temperature": 1.0,
      "stream": false,
      "fallback_models": ["wsl-llm/nemotron-nano-4b"],
      "prompt_append": "Provide careful analysis of code patterns, potential optimizations, and edge cases.",
    },

    // Code fixing — 35b fast for targeted single-file fixes
    "hephaestus": {
      "model": "local-llm/qwen35-moe-35b",
      "temperature": 0.6,
      "stream": false,
      "maxTokens": 16384,
    },

    // Prometheus — 122b-mxp with parallel deep-agent hints
    "prometheus": {
      "model": "local-llm/qwen35-122b-mxp",
      "temperature": 0.6,
      "prompt_append": "Prioritize leveraging deep agents (oracle, metis) in parallel for complex analysis.",
      "stream": false,
      "fallback_models": ["local-llm/qwen35-moe-35b"],
    },

    // Subagent executor — 35b handles delegation volume
    "sisyphus-junior": {
      "model": "local-llm/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Subagent executor for category-based task delegation",
    },

    // Task builder — 35b for structured task execution
    "OpenCode-Builder": {
      "model": "local-llm/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Builds and executes tasks via the task system",
    },

    // Plan agent — 122b-mxp for structured multi-step planning
    // Benefits most from the 131K context (can see entire codebase while planning)
    "plan": {
      "model": "local-llm/qwen35-122b-mxp",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Generates structured work plans for multi-step tasks",
    },

    // Build/test agent — 35b sufficient for build ops
    "build": {
      "model": "local-llm/qwen35-moe-35b",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Handles build, test, and lint operations",
    },
  },

  // ============================================================================
  // CATEGORIES
  // ============================================================================
  "categories": {
    // Trivial — 35b
    "quick": {
      "model": "local-llm/qwen35-moe-35b",
      "description": "Quick fixes, minor edits, simple refactoring",
    },

    // Standard — 35b
    "unspecified-low": {
      "model": "local-llm/qwen35-moe-35b",
      "description": "Standard code generation and modifications",
    },

    // Complex — 122b-mxp (131K context shines on multi-file changes)
    "unspecified-high": {
      "model": "local-llm/qwen35-122b-mxp",
      "description": "Complex refactoring, architecture decisions, multi-file changes",
    },

    // Docs/prose — 35b
    "writing": {
      "model": "local-llm/qwen35-moe-35b",
      "description": "Documentation, comments, and prose writing",
    },

    // Git ops — 35b
    "git": {
      "model": "local-llm/qwen35-moe-35b",
      "description": "Git operations, commit messages, branch management",
    },

    // Debugging — 122b-mxp (large context = full stack trace + codebase at once)
    "debugging": {
      "model": "local-llm/qwen35-122b-mxp",
      "description": "Bug investigation, error analysis, root cause analysis",
    },

    // Optimization — 122b-mxp
    "optimization": {
      "model": "local-llm/qwen35-122b-mxp",
      "description": "Performance analysis, bottleneck identification, optimization strategies",
    },

    // Code review — 122b-mxp
    "code-review": {
      "model": "local-llm/qwen35-122b-mxp",
      "description": "Code review, quality analysis, best practices",
    },

    // Visual/UI — 35b (fast iteration cycle)
    "visual-engineering": {
      "model": "local-llm/qwen35-moe-35b",
      "description": "Frontend, UI/UX, design, styling, animation",
    },
  },

  // ============================================================================
  // PROVIDERS
  // ============================================================================
  "providers": {
    "local-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Strix Halo (llama.cpp)",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        // 122B MXP — deep reasoning, large context
        // Use for: oracle, metis, plan, debugging, code-review, optimization
        "qwen35-122b-mxp": {
          "name": "qwen35-122b-mxp",
          "cost": { "input": 0.3, "output": 0.3 },
          "limit": {
            "context": 131072, // double vs q6k — use it for plan/oracle
            "output": 32768,
          },
        },
        // 35B MoE — fast, efficient, handles standard + trivial tasks
        // Use for: hephaestus, build, librarian, explore, git, writing, quick
        "qwen35-moe-35b": {
          "name": "qwen35-moe-35b",
          "cost": { "input": 0.3, "output": 0.3 },
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },
  },

  // ============================================================================
  // BACKGROUND TASKS
  // Concurrency tuned for single provider, two models on same hardware.
  // 122b-mxp is heavier — keep at 1 to avoid VRAM contention.
  // 35b MoE is efficient — allow 2 concurrent slots.
  // ============================================================================
  "background_task": {
    "providerConcurrency": {
      "local-llm": 3, // 1 for 122b + 2 for 35b
    },
    "modelConcurrency": {
      "local-llm/qwen35-122b-mxp": 1,
      "local-llm/qwen35-moe-35b": 2,
    },
  },

  // ============================================================================
  // REST OF SETTINGS (unchanged from your original)
  // ============================================================================
  "new_task_system_enabled": true,

  "skills": { "enabled": true },
  "hooks": { "enabled": true, "disabled_hooks": [] },
  "commands": { "enabled": true },
  "browser_automation": { "enabled": false },

  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
  },

  "comment_checker": { "enabled": true },
  "notification": { "force_enable": true },

  "disabled_mcps": ["websearch", "grep_app"],

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 30,
    "timeout_seconds": 60,
    "notify_on_fallback": true,
  },

  "hashline_edit": true,

  "experimental": {
    "truncate_all_tool_outputs": false,
    "aggressive_truncation": true,
    "auto_resume": true,
    "disable_omo_env": false,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": { "enabled": true, "turns": 2 },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search",
      ],
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 3 },
      },
    },
  },

  "tmux": { "enabled": false },
}
