{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",

  // Default model for top-level delegation
  "model": "local-llm/qwen35-122b-q6k",

  // ============================================================================
  // AGENTS
  // ============================================================================
  "agents": {
    // Main orchestrator — 122B for quality output
    "sisyphus": {
      "model": "local-llm/qwen35-122b-q6k",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["wsl-windows/qwen3.5-9b-q4-k-m"],
    },

    // Architecture consultation — 122B deep reasoning
    "oracle": {
      "model": "local-llm/qwen35-122b-q6k",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "fallback_models": ["wsl-windows/qwen3.5-9b-q4-k-m"],
      "prompt_append": "Focus on architectural patterns, system design, and long-horizon reasoning. Consider scalability and maintainability.",
    },

    // Research/triage — 9B lightweight
    "librarian": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
    },

    // Exploration — 9B lightweight
    "explore": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "temperature": 0.6,
      "top_p": 0.95,
      "stream": false,
    },

    // Metaprogramming — 122B deep reasoning
    "metis": {
      "model": "local-llm/qwen35-122b-q6k",
      "temperature": 1.0,
      "stream": false,
      "fallback_models": ["wsl-windows/qwen3.5-9b-q4-k-m"],
      "prompt_append": "Provide careful analysis of code patterns, potential optimizations, and edge cases.",
    },

    // Code fixing — 9B fast enough for targeted fixes
    "hephaestus": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "temperature": 0.6,
      "stream": false,
      "maxTokens": 16384,
    },

    // Prometheus — 122B with parallel deep-agent hints
    "prometheus": {
      "model": "local-llm/qwen35-122b-q6k",
      "temperature": 0.6,
      "prompt_append": "Prioritize leveraging deep agents (oracle, metis) in parallel for complex analysis.",
      "stream": false,
      "fallback_models": ["wsl-windows/qwen3.5-9b-q4-k-m"],
    },

    // Subagent executor — 9B handles delegation volume
    "sisyphus-junior": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Subagent executor for category-based task delegation",
    },

    // Task builder — 9B for structured task execution
    "OpenCode-Builder": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Builds and executes tasks via the task system",
    },

    // Plan agent — 122B for structured multi-step planning
    "plan": {
      "model": "local-llm/qwen35-122b-q6k",
      "temperature": 1.0,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Generates structured work plans for multi-step tasks",
    },

    // Build/test agent — 9B sufficient for build ops
    "build": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "temperature": 0.6,
      "top_p": 0.95,
      "maxTokens": 32768,
      "stream": false,
      "description": "Handles build, test, and lint operations",
    },
  },

  // ============================================================================
  // CATEGORIES
  // ============================================================================
  "categories": {
    // Trivial — 9B
    "quick": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "description": "Quick fixes, minor edits, simple refactoring",
    },

    // Standard — 9B
    "unspecified-low": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "description": "Standard code generation and modifications",
    },

    // Complex — 122B
    "unspecified-high": {
      "model": "local-llm/qwen35-122b-q6k",
      "description": "Complex refactoring, architecture decisions, multi-file changes",
    },

    // Docs/prose — 9B
    "writing": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "description": "Documentation, comments, and prose writing",
    },

    // Git ops — 9B
    "git": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "description": "Git operations, commit messages, branch management",
    },

    // Debugging — 122B
    "debugging": {
      "model": "local-llm/qwen35-122b-q6k",
      "description": "Bug investigation, error analysis, root cause analysis",
    },

    // Optimization — 122B
    "optimization": {
      "model": "local-llm/qwen35-122b-q6k",
      "description": "Performance analysis, bottleneck identification, optimization strategies",
    },

    // Code review — 122B
    "code-review": {
      "model": "local-llm/qwen35-122b-q6k",
      "description": "Code review, quality analysis, best practices",
    },

    // Visual/UI — 9B (fast iteration cycle)
    "visual-engineering": {
      "model": "wsl-windows/qwen3.5-9b-q4-k-m",
      "description": "Frontend, UI/UX, design, styling, animation",
    },
  },

  // ============================================================================
  // PROVIDERS
  // ============================================================================
  "providers": {
    "local-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Strix Halo (llama.cpp)",
      "options": {
        "baseURL": "http://minisforum.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen35-122b-q6k": {
          "name": "qwen35-122b-q6k",
          "cost": { "input": 0.40, "output": 0.40 },
          "limit": { "context": 65536, "output": 32768 },
        },
      },
    },

    "wsl-windows": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "WSL Windows (Qwen 3.5 9B)",
      "options": {
        "baseURL": "http://wsl-windows.tailfe1a8c.ts.net:8080/v1",
        "apiKey": "not-needed",
      },
      "models": {
        "qwen3.5-9b-q4-k-m": {
          "name": "qwen3.5-9b-q4-k-m",
          "cost": { "input": 0.20, "output": 0.20 },
          "limit": { "context": 65536, "output": 32768 },
        },
      },
    },
  },

  // ============================================================================
  // BACKGROUND TASKS — Concurrency tuned to 2-model setup
  // ============================================================================
  "background_task": {
    "providerConcurrency": {
      "local-llm": 1,      // 122B Q6 is heavy — keep at 1
      "wsl-windows": 4,    // 9B is light — allow parallel slots
    },
    "modelConcurrency": {
      "local-llm/qwen35-122b-q6k": 1,
      "wsl-windows/qwen3.5-9b-q4-k-m": 4,
    },
  },

  // ============================================================================
  // REST OF YOUR EXISTING SETTINGS (unchanged)
  // ============================================================================
  "new_task_system_enabled": true,

  "skills": { "enabled": true },
  "hooks": { "enabled": true, "disabled_hooks": [] },
  "commands": { "enabled": true },
  "browser_automation": { "enabled": false },

  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
  },

  "comment_checker": { "enabled": true },
  "notification": { "force_enable": true },

  "disabled_mcps": ["websearch", "grep_app"],

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 30,
    "timeout_seconds": 60,
    "notify_on_fallback": true,
  },

  "hashline_edit": true,

  "experimental": {
    "truncate_all_tool_outputs": false,
    "aggressive_truncation": true,
    "auto_resume": true,
    "disable_omo_env": false,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": { "enabled": true, "turns": 2 },
      "protected_tools": [
        "task", "todowrite", "todoread",
        "lsp_rename", "session_read", "session_write", "session_search",
      ],
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 3 },
      },
    },
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384,
  },

  "plugin": ["oh-my-opencode@latest"],

  "tmux": { "enabled": false },
}